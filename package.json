{
	"private": true,
	"name": "quickmeme",
	"version": "0.0.0",
	"license": "MIT",
	"scripts": {
		"start": "per-env",
		"start:production": "npm run -s serve",
		"start:development": "npm run -s dev",
		"build_old": "preact build",
		"serve": "preact build && serve build --single",
		"dev": "preact watch",
		"lint": "eslint src",
		"test": "jest",
		"build": "rm -rf dist && webpack && npm run copy:dist",
		"copy:dist": "cp ./src/popup.html manifest.json ./dist"
	},
	"eslintConfig": {
		"extends": "eslint-config-synacor"
	},
	"eslintIgnore": [
		"build/*"
	],
	"devDependencies": {
		"css-loader": "^3.2.0",
		"enzyme": "^3.10.0",
		"enzyme-adapter-preact-pure": "^2.0.0",
		"eslint": "^6.0.1",
		"eslint-config-synacor": "^3.0.4",
		"file-loader": "^5.0.2",
		"identity-obj-proxy": "^3.0.0",
		"jest": "^24.9.0",
		"jest-preset-preact": "^1.0.0",
		"per-env": "^1.0.2",
		"preact-cli": "^3.0.0-rc.6",
		"preact-render-spy": "^1.2.1",
		"serve": "^11.1.0",
		"url-loader": "^2.3.0",
		"webpack-cli": "^3.3.10"
	},
	"dependencies": {
		"preact": "^10.0.1",
		"preact-html-converter": "^0.4.2",
		"preact-render-to-string": "^5.1.0",
		"preact-router": "^3.0.0",
		"react-html-parser": "^2.0.2"
	},
	"jest": {
		"preset": "jest-preset-preact",
		"setupFiles": [
			"<rootDir>/tests/__mocks__/browserMocks.js",
			"<rootDir>/tests/__mocks__/setupTests.js"
		]
	}
}
